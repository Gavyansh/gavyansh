generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
}

model Product {
  id          String   @id
  name        String
  description String   @default("")
  image       String
  /// Up to 3 gallery image URLs (Cloudinary or /images/...). Primary/cover is `image` (kept in sync with images[0]).
  images      Json     @default("[]")
  benefits    Json     @default("[]")
  variants    Json     @default("[]")
  createdAt   DateTime @default(now())
}

model Order {
  id                 String      @id
  userId             String?
  paymentMethod      String?
  razorpayPaymentId  String?
  razorpayOrderId    String?
  customerName       String
  customerEmail      String
  customerPhone      String
  customerAddress    String
  customerCity       String?
  customerState      String?
  customerPincode    String?
  total              Float
  shiprocketOrderId  String?
  awb                String?
  createdAt          DateTime    @default(now())
  items              OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  weight    String
  price     Float
  quantity  Int
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

/// Optional: store media URLs (Cloudinary, etc.) for future gallery / product videos
model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  kind      String   @default("image") // image | video
  label     String?
  createdAt DateTime @default(now())
}
