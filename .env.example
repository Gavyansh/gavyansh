# Server
PORT=3000

# Auth (Railway + local) - use a random string in production
JWT_SECRET="your-secret-key-change-in-production"

# Vercel + Railway: Set on Vercel only. Your Railway API URL
VITE_API_URL=""

# Razorpay (Railway + optional on Vercel for key)
# Get from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxx"
VITE_RAZORPAY_KEY_ID=""  # Optional on Vercel - backend returns it if not set

# Shiprocket (Railway) - for automated shipping
# Get from Shiprocket Dashboard → Settings → API
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""
SHIPROCKET_PICKUP_LOCATION="Primary"  # Your pickup location name in Shiprocket

# Email (Resend - Railway blocks SMTP)
# Get API key from https://resend.com → API Keys
# Free tier: 100 emails/day, 3000/month
RESEND_API_KEY="re_xxxxxxxx"
ORDER_FROM_EMAIL="onboarding@resend.dev"  # Optional: use verified domain after setup
ORDER_FROM_NAME="Gavyansh Vedic Ghee"
ORDER_NOTIFY_EMAIL="info1gavyansh@gmail.com"  # Where to receive new orders & contact form

# Image upload (Vercel) - Cloudinary for product images
# Get from https://cloudinary.com → Dashboard → Settings
# Create an unsigned upload preset in Upload settings
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""

# Optional: AI Studio / Gemini (if using AI features)
GEMINI_API_KEY=""
APP_URL="http://localhost:3000"
